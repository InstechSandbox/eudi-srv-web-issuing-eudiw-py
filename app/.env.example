# Local host and port defaults for local helper scripts.
# The local patch script rewrites these as needed for your machine.
MYIP=127.0.0.1
ISSUER_PORT=5002
AUTH_PORT=5001
FRONTEND_PORT=5003
LOCAL_REPO_ROOT=/absolute/path/to/eudi-srv-web-issuing-eudiw-py

# Service Configuration
SERVICE_URL=https://${MYIP}:${ISSUER_PORT}
WALLET_TEST_URL=https://dev.tester.issuer.eudiw.dev/

# Frontend
DEFAULT_FRONTEND=5d725b3c-6d42-448e-8bfd-1eff1fcf152d
DEFAULT_FRONTEND_URL=https://${MYIP}:${FRONTEND_PORT}
# Paths
TRUSTED_CAS_PATH=${LOCAL_REPO_ROOT}/local/cert/
PRIVKEY_PATH=${LOCAL_REPO_ROOT}/local/privKey/

# Keys (update paths for your environment)
NONCE_KEY=${LOCAL_REPO_ROOT}/local/privKey/nonce_rsa2048.pem
CREDENTIAL_KEY=${LOCAL_REPO_ROOT}/local/privKey/credential_request_ec.pem

# Internal Services
#AUTH_SERVER_INTERNAL_URL=https://127.0.0.1:${AUTH_PORT} #Docker/local
AUTH_SERVER_INTERNAL_URL=https://127.0.0.1:${AUTH_PORT}
AUTH_SERVER_VERIFY_TLS=false
SERVICE_VERIFY_TLS=false

# Local-only fallbacks. Keep disabled unless you are running a partial local stack.
ALLOW_MISSING_REVOCATION_DATA=true
ALLOW_LOCAL_UTOPIA_SIGNER_FALLBACK=true
VERIFY_USER_ENDPOINT=https://${MYIP}:${AUTH_PORT}/verify/user

# External Services
DYNAMIC_PRESENTATION_URL=https://localhost/ui/presentations/

REVOCATION_API_KEY=test
REVOCATION_SERVICE_URL=https://${MYIP}:${ISSUER_PORT}/token_status_list/take
REVOKE_SERVICE_URL=https://${MYIP}:${ISSUER_PORT}/token_status_list/set

OID4VP_SCHEME=haip-vp://
CREDENTIAL_OFFER_SCHEME=haip-vci://

EIDAS_NODE_CONNECTOR_URL=https://eidas.projj.eu
EIDAS_NODE_CLIENT_ID=example
EIDAS_NODE_CLIENT_SECRET=example

PT_CLIENT_ID=example
PT_CLIENT_SECRET=example

EE_CLIENT_ID=example
EE_BASIC_AUTHORIZATION_HEADER=Basic example

EE_REDIRECT_URI=https://pprpid.provider.eudiw.projj.eu/tara/redirect

#Issuer Back-end log file
LOG_FILE=/tmp/log_dev/logs.log

#Authorization server log file for /logs endpoint
AUTH_LOG_FILE=/tmp/oidc_log_dev/logs.log